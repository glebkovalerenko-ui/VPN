# Local environment
.env

# Runtime data
/data/logs/*
!/data/logs/.gitkeep
/data/snapshots/*
!/data/snapshots/.gitkeep
/output/*
!/output/.gitkeep
!/output/BLACK-ETALON.txt
!/output/WHITE-CIDR-ETALON.txt
!/output/WHITE-SNI-ETALON.txt
!/output/ALL-ETALON.txt
!/output/export_manifest.json

# Python cache/artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
