PROJECT_NAME=proxy-mvp
TZ=Europe/Moscow

POSTGRES_DB=proxy_mvp
POSTGRES_USER=proxy_user
POSTGRES_PASSWORD=change_me
# For compose runtime use "db"; for host-local CLI without containers use "127.0.0.1".
POSTGRES_HOST=db
POSTGRES_PORT=5432
API_PORT=8000
DATABASE_URL=

FETCH_INTERVAL_MINUTES=15
ORCHESTRATOR_STARTUP_DELAY_SECONDS=5
ORCHESTRATOR_EXIT_ON_FAILURE=false
PROBE_BATCH_SIZE=200
CHECK_FRESHNESS_MINUTES=60
MAX_SELECTION_AGE_MINUTES=180

EXPORT_BLACK_LIMIT=5000
EXPORT_WHITE_CIDR_LIMIT=2000
EXPORT_WHITE_SNI_LIMIT=2000
EXPORT_ALL_LIMIT=10000
EXPORT_MAX_PER_COUNTRY=2
EXPORT_MAX_PER_HOST=1
EXPORT_MAX_LATENCY_MS=3200
EXPORT_MAX_FIRST_BYTE_MS=2400
EXPORT_MIN_DOWNLOAD_MBPS=2.0
EXPORT_REQUIRE_SPEED_MEASUREMENT=true
EXPORT_ALLOW_LEGACY_SPEED_IF_OTHER_SIGNALS_STRONG=false
EXPORT_REQUIRE_LATEST_CHECK_SUCCESS=true
EXPORT_MAX_LATEST_CHECK_AGE_MINUTES=75
EXPORT_REQUIRE_LAST_TWO_SUCCESSES=false
EXPORT_REQUIRE_CONSECUTIVE_SUCCESSES=true
EXPORT_MIN_CONSECUTIVE_SUCCESSES=1
EXPORT_RECENT_CHECKS_WINDOW=5
EXPORT_MIN_RECENT_SUCCESS_RATIO=0.75
EXPORT_MIN_USER_TARGET_SUCCESS_RATIO=0.80
EXPORT_REQUIRE_CRITICAL_TARGETS_ALL_SUCCESS=false
EXPORT_MIN_CRITICAL_TARGET_SUCCESS_RATIO=0.50
EXPORT_MIN_FRESHNESS_SCORE=0.75

GEO_PROVIDER_PRIMARY=ip-api
GEO_PROVIDER_FALLBACK=ipwhois
GEO_REQUEST_TIMEOUT_SECONDS=6
GEO_IP_API_BASE_URL=http://ip-api.com/json
GEO_IPWHOIS_BASE_URL=https://ipwho.is
# Comma-separated deterministic endpoint list. SPEED_TEST_URL is kept as a legacy fallback.
SPEED_TEST_URLS=http://cachefly.cachefly.net/1mb.test,https://speed.cloudflare.com/__down?bytes=1048576,https://proof.ovh.net/files/1Mb.dat
SPEED_TEST_URL=http://cachefly.cachefly.net/1mb.test
SPEED_TEST_ATTEMPTS=3
SPEED_TEST_CONNECT_TIMEOUT_SECONDS=6
SPEED_TEST_READ_TIMEOUT_SECONDS=12
SPEED_TEST_MAX_BYTES=1048576
SPEED_TEST_CHUNK_SIZE=65536
CONNECT_TIMEOUT_SECONDS=10
DOWNLOAD_TIMEOUT_SECONDS=20
SINGBOX_BINARY=sing-box
PROBER_LOCAL_BIND_HOST=127.0.0.1
PROBER_BASE_LOCAL_PORT=39000
PROBER_PROCESS_START_TIMEOUT_SECONDS=8
PROBER_EXIT_IP_URL=https://api.ipify.org?format=json
PROBER_MULTIHOST_ENABLED=true
PROBER_BASELINE_URLS=https://api.ipify.org?format=json,https://example.com/
PROBER_CRITICAL_URLS=https://www.google.com/generate_204,https://www.cloudflare.com/cdn-cgi/trace
# If empty, falls back to SPEED_TEST_URLS (bounded by PROBER_MULTIHOST_MAX_TARGETS_PER_GROUP).
PROBER_SPEED_URLS=
PROBER_MIN_USER_TARGET_SUCCESS_RATIO=0.80
PROBER_REQUIRE_CRITICAL_TARGETS_ALL_SUCCESS=true
PROBER_MIN_CRITICAL_TARGET_SUCCESS_RATIO=0.95
PROBER_MAX_TARGET_FIRST_BYTE_MS=2200
PROBER_MAX_TARGET_LATENCY_MS=4500
PROBER_MULTIHOST_MAX_TARGETS_PER_GROUP=2
PROBER_TEMP_DIR=

SCORER_RECENT_CHECKS_LIMIT=20
SCORER_MIN_ACTIVE_STABILITY=0.75
SCORER_MIN_DEGRADED_STABILITY=0.25
SCORER_LATENCY_GOOD_MS=250
SCORER_LATENCY_BAD_MS=1800
SCORER_SPEED_GOOD_MBPS=30
SCORER_SPEED_BAD_MBPS=1.5
SCORER_MIN_ACTIVE_FRESHNESS=0.60
SCORER_DEAD_FRESHNESS_MAX=0.05
SCORER_FRESHNESS_PENALTY_WEIGHT=0.35
SCORER_MISSING_SPEED_PENALTY=0.08

PUBLISH_ENABLED=false
PUBLISH_REMOTE=origin
PUBLISH_BRANCH=main
PUBLISH_GIT_AUTHOR_NAME=proxy-mvp-bot
PUBLISH_GIT_AUTHOR_EMAIL=proxy-mvp-bot@users.noreply.github.com
PUBLISH_COMMIT_MESSAGE_PREFIX=chore(exports): refresh etalon outputs
PUBLISH_AUTH_MODE=auto
# Non-interactive HTTPS auth for publisher (set exactly one token).
GITHUB_TOKEN=
GH_TOKEN=
# Optional SSH override if you use SSH remote and mounted keys.
GIT_SSH_COMMAND=
PUBLISH_PUSH_TIMEOUT_SECONDS=60
